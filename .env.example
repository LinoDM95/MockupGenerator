# ============================================================
# MOCKUP GENERATOR — ENVIRONMENT TEMPLATE
# Kopiere nach backend/.env und fülle die Werte.
# NIEMALS echte Werte committen!
# ============================================================

# --- Django Core (PFLICHT) ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Datenbank (optional lokal: leer = SQLite) ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Token-Verschlüsselung (PFLICHT) ---
# Fernet-Key (URL-safe base64, 32 Bytes). In Produktion: TOKEN_ENCRYPTION_KEY setzen.
TOKEN_ENCRYPTION_KEY=
# Legacy-Alias (wird gelesen, wenn TOKEN_ENCRYPTION_KEY leer) — bitte auf TOKEN_ENCRYPTION_KEY umstellen.
# ETSY_TOKEN_ENCRYPTION_KEY=

# --- Celery (ohne Redis: CELERY_TASK_ALWAYS_EAGER=true) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Cloudflare R2 (optional) ---
# Mit gesetztem Bucket (Beispiel-Pfade):
#   template_backgrounds/users/<user_id>/YYYY/MM/…  — Vorlagen-Hintergründe (dauerhaft)
#   temp_designs/users/<user_id>/YYYY/MM/…         — Gelato-Temp (Cleanup)
#   gelato_artworks/users/<user_id>/…              — Bulk-Artworks vor Gelato-Job
# Im R2-Bucket CORS: GET von deiner App-Origin erlauben (Generator-ZIP / Canvas mit crossOrigin; optional Set-Duplizieren per fetch).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# --- Etsy OAuth (optional) ---
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=http://127.0.0.1:5173/etsy/callback
ETSY_SCOPES=shops_r listings_r listings_w

# --- Pinterest OAuth (optional) ---
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://127.0.0.1:5173/pinterest/callback
PINTEREST_SCOPES=pins:read,pins:write,boards:read,boards:write,user_accounts:read

R2_TEMP_DESIGN_MAX_AGE_HOURS=24
R2_TEMP_CLEANUP_COOLDOWN_SECONDS=300

MARKETING_PIN_IMAGE_URL_ALLOWED_HOSTS=

# Zusätzliche Origins für die Local Engine (Browser → http://127.0.0.1:8001).
# Standard im Companion: Vite :5173/:4173 und Django-SPA :8000 — für andere Hosts/HTTPS hier setzen, z. B.:
# COMPANION_CORS_ORIGINS=https://app.example.com,https://www.example.com
COMPANION_CORS_ORIGINS=

# --- Monitoring (optional) ---
SENTRY_DSN=

# --- Frontend (Vite): Impressum/Datenschutz/AGB ---
# Siehe frontend/frontend/.env.example — Variablen VITE_APP_DISPLAY_NAME, VITE_LEGAL_* dort setzen.
