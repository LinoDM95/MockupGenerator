# Kopie als backend/.env speichern (nicht nur .env.example). Django lädt backend/.env automatisch.
# Etsy-App: dieselbe Redirect-URL wie hier in der Etsy Developer Console eintragen.

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Worker (separates Terminal):
#   celery -A config worker -l info

# Etsy API v3 (Developer Console) — ETSY_CLIENT_ID ist Pflicht für „Etsy verknüpfen“
ETSY_CLIENT_ID=deine-string-key-id-von-etsy
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=http://127.0.0.1:5173/etsy/callback
ETSY_SCOPES=shops_r listings_r listings_w
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ETSY_TOKEN_ENCRYPTION_KEY=
ETSY_API_RPS=10
